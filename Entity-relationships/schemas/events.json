{
    "name": "extract_clean_tech_events",
    "description": "Extracts structured events from a clean technology investment article.",
    "parameters": {
      "type": "object",
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "event": {
                "type": "string",
                "enum": [
                  "new_announcement",
                  "expansion_announcement",
                  "construction_starts",
                  "construction_ends",
                  "operations_start"
                ]
              },
              "date": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["new", "expansion", "null"]
              }
            },
            "required": ["id", "event", "date", "type"]
          }
        }
      },
      "required": ["events"]
    }
  }