{
    "name": "extract_characteristics",
    "description": "Extracts status and type information about production capacities from a clean technology investment article.",
    "parameters": {
      "type": "object",
      "properties": {
        "node_characteristics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "capacity_ID": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["operational", "under construction", "announced", "cancelled", "unclear"]
              },
              "phase": {
                "type": "string",
                "enum": ["greenfield", "expansion", "retrofit", "unclear"]
              },
              "additional": {
                "type": "boolean"
              }
            },
            "required": ["capacity_ID", "status", "phase", "additional"]
          }
        }
      },
      "required": ["node_characteristics"]
    }
  }