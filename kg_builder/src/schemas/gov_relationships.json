{
    "name": "extract_government_relationships",
    "description": "Extracts relationships: government issues support_package or tax_cut; support_package and tax_cut target product.",
    "parameters": {
        "type": "object",
        "properties": {
            "relationships": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "source": {"type": "string"},
                        "target": {"type": "string"},
                        "type": {
                            "type": "string",
                            "enum": ["issues", "targets"]
                        }
                    },
                    "required": ["source", "target", "type"]
                }
            }
        },
        "required": ["relationships"]
    }
}
