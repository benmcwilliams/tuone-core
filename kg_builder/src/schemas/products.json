{
    "name": "normalise_products",
    "description": "Classified a product according to the product_lv1, product_lv2 and product_lv3 classification",
    "parameters": {
      "type": "object",
      "properties": {
        "node_characteristics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "product_ID": { "type": "string" },
              "product_lv1": {
                "type": ["string", "null"]
              },
              "product_lv2": {
                "type": ["string", "null"]
              },
              "product_lv3": {
                "type": ["string", "null"]
              }
            },
            "required": ["product_ID", "product_lv1", "product_lv2"]
          }
        }
      },
      "required": ["node_characteristics"]
    }
  }