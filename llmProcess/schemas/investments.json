{
    "name": "extract_characteristics",
    "description": "Extracts status and type information about investments from a clean technology investment article.",
    "parameters": {
      "type": "object",
      "properties": {
        "node_characteristics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "investment_ID": { "type": "string" },
              "status": {
                "type": ["string", "null"],
                "enum": ["completed", "ongoing", "announced", "unclear"]
              },
              "phase": {
                "type": ["string", "null"],
                "enum": ["greenfield", "expansion", "retrofit", "unclear"]
              }
            },
            "required": ["investment_ID", "status", "phase"]
          }
        }
      },
      "required": ["node_characteristics"]
    }
  }